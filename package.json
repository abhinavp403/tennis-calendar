{
  "name": "tennis_calendar",
  "version": "1.0.0",
  "description": "",
  "main": "electron/main.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.3",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "dayjs": "^1.11.20",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:vite": "vite",
    "build": "vite build",
    "start": "electron .",
    "dist": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.tennis.calendar",
    "productName": "Tennis Calendar",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "scripts/**/*",
      "data/**/*",
      "public/**/*"
    ],
    "mac": {
      "target": "dmg",
      "icon": "public/logos/wimbledon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "public/logos/wimbledon.png"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
